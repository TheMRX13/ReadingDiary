# ══════════════════════════════════════════════════════════════════
#  Reading Diary – Environment Configuration
#  WICHTIG: Diese Datei niemals committen! Kopiere sie zu .env
# ══════════════════════════════════════════════════════════════════

# ── Flask Secret Key ──────────────────────────────────────────────
# Generiere einen sicheren Schlüssel: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_secure_random_key_here

# ── Administrator-Account ─────────────────────────────────────────
# Wird beim ersten Start automatisch erstellt
ADMIN_USERNAME=admin
ADMIN_EMAIL=your-admin@email.com
# Passwort-Anforderungen: mind. 10 Zeichen, 1 Groß, 1 Klein, 1 Sonderzeichen
ADMIN_PASSWORD=CHANGE_ME_SecureAdminPW!

# ── SMTP (implizites TLS / SMTPS Port 465) ───────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASSWORD=CHANGE_ME_smtp_password
SMTP_FROM=Reading Diary <noreply@example.com>

# ── Sicherheit ───────────────────────────────────────────────────
# IP-Sperre: Nur Anfragen vom Nginx-Proxy erlauben (0=deaktiviert für Dev, 1=aktiv)
ENABLE_IP_LOCK=1
# Erlaubte IPs (kommagetrennt): nginx-Proxy + localhost + Docker-Gateway
ALLOWED_IPS=127.0.0.1,172.18.0.1,87.106.58.226

# ── App-Konfiguration ─────────────────────────────────────────────
# Basis-URL für E-Mail-Links (ohne abschließenden Slash)
APP_BASE_URL=https://yourdomain.com
# Zeitzone für Anzeige
APP_TIMEZONE=Europe/Berlin
